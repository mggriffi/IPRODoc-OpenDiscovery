<?xml version="1.0" encoding="utf-8"?>
<CatapultTarget
  Version="2"
  Comment="Eclipse Help Target for Test Help Center"
  Type="WebHelp2"
  Destinations=""
  GlossaryTermConversion="first"
  DisableAutoSync="false"
  SearchEngine="MadCapSearch"
  ConditionTagExpression="include[Primary.Eclipse or Primary.Shared_EclandCloud or Primary.Target_Online] exclude[Primary.Admin or Primary.Blank or Primary.CaseMgmt or Primary.Find_Images or Primary.Media_Manager or Primary.Processing or Primary.Reports or Primary.Review or Primary.SampleTopics or Primary.Self_Service or Primary.Target_Print or &quot;Primary.Z_Excluded V1&quot; or Primary.eCap_editdone or Primary.eCap_partial] "
  RemoveMadCapStyles="true"
  Skin="/Project/Skins/EclipseHelp.flskn"
  MasterToc="/Project/TOCs/Eclipse.fltoc"
  conditions=""
  GetLatestBeforeCompile="true"
  TopNavTocPath="true"
  EnableSitemap="true"
  SitemapWebUrl="https://iprohelpqa.testing.local/EclipseHelp/">
  <PrintedOutput
    CollapseMargins="true"
    GenerateTOCProxy="true"
    GenerateIndexProxy="true"
    GenerateGlossaryProxy="true" />
  <Glossaries>
    <Glossary
      Link="/Project/Glossaries/ADD_Help.flglo" />
    <Glossary
      Link="/Project/Glossaries/Admin.flglo" />
    <Glossary
      Link="/Project/Glossaries/MediaManager.flglo" />
    <Glossary
      Link="/Project/Glossaries/Processing.flglo" />
    <Glossary
      Link="/Project/Glossaries/Reports.flglo" />
    <Glossary
      Link="/Project/Glossaries/Review.flglo" />
    <Glossary
      Link="/Project/Glossaries/SelfService.flglo" />
  </Glossaries>
  <Destinations>
    <Destination
      Publish="true" />
  </Destinations>
</CatapultTarget>