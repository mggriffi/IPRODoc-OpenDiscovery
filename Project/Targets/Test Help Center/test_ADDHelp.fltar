<?xml version="1.0" encoding="utf-8"?>
<CatapultTarget
  Version="2"
  Comment="ADD help target for Test Help Center"
  Type="WebHelp2"
  Destinations=""
  GlossaryTermConversion="first"
  DisableAutoSync="false"
  SearchEngine="MadCapSearch"
  ConditionTagExpression="include[Primary.Admin or Primary.CaseMgmt or Primary.Media_Manager or Primary.Reports or Primary.Review or Primary.Self_Service or Primary.Shared_EclandCloud or &quot;Primary.Upcoming Release&quot;] exclude[Primary.Blank or Primary.Blocked or Primary.Eclipse or Primary.FutureDelete or Primary.Processing or Primary.SampleTopics or Primary.Target_Online or Primary.Target_Print or &quot;Primary.Z_Excluded V1&quot; or Primary.eCap_editdone or Primary.eCap_partial] "
  RemoveMadCapStyles="true"
  Skin="/Project/Skins/ADDHelp.flskn"
  MasterToc="/Project/TOCs/ADD_Help_w_ADD_Review.fltoc"
  conditions=""
  GetLatestBeforeCompile="true"
  TopNavTocPath="true"
  DefaultUrl="/Content/Enterprise_old.htm"
  EnableSitemap="true"
  SitemapWebUrl="https://iprohelpqa.testing.local/Cloud/">
  <PrintedOutput
    CollapseMargins="true"
    GenerateTOCProxy="true"
    GenerateIndexProxy="true"
    GenerateGlossaryProxy="true" />
  <Glossaries>
    <Glossary
      Link="/Project/Glossaries/ADD_Help.flglo" />
    <Glossary
      Link="/Project/Glossaries/Admin.flglo" />
    <Glossary
      Link="/Project/Glossaries/MediaManager.flglo" />
    <Glossary
      Link="/Project/Glossaries/Processing.flglo" />
    <Glossary
      Link="/Project/Glossaries/Reports.flglo" />
    <Glossary
      Link="/Project/Glossaries/Review.flglo" />
    <Glossary
      Link="/Project/Glossaries/SelfService.flglo" />
  </Glossaries>
  <Destinations>
    <Destination
      Publish="true" />
  </Destinations>
</CatapultTarget>