  RemoveMadCapStyles="true"
  Skin="/Project/Skins/beta_myIPRO_Side Nav.flskn"
  MasterToc="/Project/TOCs/Eclipse.fltoc"
  conditions=""
  GetLatestBeforeCompile="true"
